From b8a3c7d9e2f1a5b6c7d8e9f0a1b2c3d4e5f6a7b8 Mon Sep 17 00:00:00 2001
From: PotatsoX <ichococcino@gmail.com>
Date: Wed, 25 Jun 2026 04:00:00 +0800
Subject: [PATCH] Add support for WWDK M7628 device for OpenWrt v24+

Add device tree, configuration files, and network setup for WWDK M7628
wireless router with MT7628AN SoC.

- Add optimized UCI configuration script
- Add device tree source file
- Register device in image configuration
- Add network interface mapping
---
 .../files/etc/uci-defaults/99_custom_wwdk    | 52 ++++++++++++++
 .../linux/ramips/dts/mt7628an_wwdk_m7628.dts  | 96 ++++++++++++++++++++++
 target/linux/ramips/image/mt76x8.mk           |  8 ++
 .../mt76x8/base-files/etc/board.d/02_network  |  1 +
 4 files changed, 157 insertions(+)
 create mode 100755 package/base-files/files/etc/uci-defaults/99_custom_wwdk
 create mode 100644 target/linux/ramips/dts/mt7628an_wwdk_m7628.dts

diff --git a/package/base-files/files/etc/uci-defaults/99_custom_wwdk b/package/base-files/files/etc/uci-defaults/99_custom_wwdk
new file mode 100755
index 0000000..a1b2c3d
--- /dev/null
+++ b/package/base-files/files/etc/uci-defaults/99_custom_wwdk
@@ -0,0 +1,52 @@
+#!/bin/sh
+# WWDK M7628 Custom Configuration Script
+
+. /lib/functions.sh
+. /lib/functions/uci-defaults.sh
+
+# System Configuration
+uci batch <<EOF
+set system.@system[0].hostname='WWDK-M7628'
+set system.@system[0].timezone='CST-8'
+set system.@system[0].zonename='Asia/Shanghai'
+set system.@system[0].description='WWDK Wireless Router'
+commit system
+EOF
+
+# Wireless Configuration
+uci batch <<EOF
+set wireless.@wifi-device[0].disabled=0
+set wireless.@wifi-iface[0].disabled=0
+set wireless.@wifi-device[0].channel=auto
+set wireless.@wifi-device[0].hwmode=11ng
+set wireless.@wifi-iface[0].ssid='WWDK-M7628'
+set wireless.@wifi-iface[0].encryption='psk2'
+set wireless.@wifi-iface[0].key='12345678'
+set wireless.@wifi-iface[0].mode='ap'
+commit wireless
+EOF
+
+# Network Configuration - LAN
+uci batch <<EOF
+set network.lan=interface
+set network.lan.proto='static'
+set network.lan.ifname='eth0.1'
+set network.lan.ipaddr='192.168.1.1'
+set network.lan.netmask='255.255.255.0'
+set network.lan.ip6assign='60'
+commit network
+EOF
+
+# Network Configuration - WAN
+uci batch <<EOF
+set network.wan=interface
+set network.wan.ifname='eth0.2'
+set network.wan.proto='dhcp'
+commit network
+EOF
+
+# Disable IPv6 globally (optional, comment out if IPv6 is needed)
+# uci set network.@globals[0].ula_prefix='fd00:1234:5678::/48'
+
+uci commit
+exit 0
diff --git a/target/linux/ramips/dts/mt7628an_wwdk_m7628.dts b/target/linux/ramips/dts/mt7628an_wwdk_m7628.dts
new file mode 100644
index 0000000..e0e0fb2
--- /dev/null
+++ b/target/linux/ramips/dts/mt7628an_wwdk_m7628.dts
@@ -0,0 +1,96 @@
+// SPDX-License-Identifier: GPL-2.0-or-later OR MIT
+
+#include "mt7628an.dtsi"
+
+#include <dt-bindings/gpio/gpio.h>
+#include <dt-bindings/input/input.h>
+
+/ {
+	compatible = "wwdk,m7628", "mediatek,mt7628an-soc";
+	model = "WWDK M7628";
+
+	chosen {
+		bootargs = "console=ttyS0,57600";
+	};
+
+	keys {
+		compatible = "gpio-keys";
+
+		reset {
+			label = "reset";
+			gpios = <&gpio 38 GPIO_ACTIVE_LOW>;
+			linux,code = <KEY_RESTART>;
+		};
+	};
+
+	leds {
+		compatible = "gpio-leds";
+
+		wlan {
+			label = "green:wlan";
+			gpios = <&gpio 44 GPIO_ACTIVE_LOW>;
+		};
+
+		lan {
+			label = "green:lan";
+			gpios = <&gpio 37 GPIO_ACTIVE_LOW>;
+		};
+	};
+};
+
+&state_default {
+	gpio {
+		groups = "i2c", "jtag";
+		function = "gpio";
+	};
+};
+
+&uart1 {
+	status = "okay";
+};
+
+&spi0 {
+	status = "okay";
+
+	flash@0 {
+		compatible = "jedec,spi-nor";
+		reg = <0>;
+		spi-max-frequency = <10000000>;
+		broken-flash-reset;
+
+		partitions {
+			compatible = "fixed-partitions";
+			#address-cells = <1>;
+			#size-cells = <1>;
+
+			partition@0 {
+				label = "u-boot";
+				reg = <0x0 0x30000>;
+				read-only;
+			};
+
+			partition@30000 {
+				label = "u-boot-env";
+				reg = <0x30000 0x10000>;
+				read-only;
+			};
+
+			factory: partition@40000 {
+				label = "factory";
+				reg = <0x40000 0x10000>;
+				read-only;
+			};
+
+			partition@50000 {
+				compatible = "denx,uimage";
+				label = "firmware";
+				reg = <0x50000 0xfb0000>;
+			};
+		};
+	};
+};
+
+&ethernet {
+	mtd-mac-address = <&factory 0x28>;
+};
+
+&wmac {
+	status = "okay";
+	mediatek,mtd-eeprom = <&factory 0x0>;
+};
diff --git a/target/linux/ramips/image/mt76x8.mk b/target/linux/ramips/image/mt76x8.mk
index 5b9a04d..fa82474 100644
--- a/target/linux/ramips/image/mt76x8.mk
+++ b/target/linux/ramips/image/mt76x8.mk
@@ -257,6 +257,14 @@ define Device/hilink_hlk-7688a
 endef
 TARGET_DEVICES += hilink_hlk-7688a
 
+define Device/wwdk_m7628
+  IMAGE_SIZE := 16064k
+  DEVICE_VENDOR := WWDK
+  DEVICE_MODEL := M7628
+  DEVICE_PACKAGES := uboot-envtools kmod-usb2 kmod-usb-ohci
+endef
+TARGET_DEVICES += wwdk_m7628
+
 define Device/hiwifi_hc5611
   IMAGE_SIZE := 15808k
   DEVICE_VENDOR := HiWiFi
diff --git a/target/linux/ramips/mt76x8/base-files/etc/board.d/02_network b/target/linux/ramips/mt76x8/base-files/etc/board.d/02_network
index e77bc82..9b3d92f 100644
--- a/target/linux/ramips/mt76x8/base-files/etc/board.d/02_network
+++ b/target/linux/ramips/mt76x8/base-files/etc/board.d/02_network
@@ -45,6 +45,7 @@ ramips_setup_interfaces()
 	asus,rt-ac1200|\
 	asus,rt-ac1200-v2|\
 	hilink,hlk-7628n|\
 	hilink,hlk-7688a|\
+	wwdk,m7628|\
 	hiwifi,hc5861b|\
 	keenetic,kn-1711|\
 	kroks,kndrt31r16|\
